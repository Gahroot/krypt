{
  "name": "cryptomaple",
  "private": true,
  "version": "0.0.0",
  "description": "A 2D side-scroller MMORPG with a player-owned free market. Game-first; crypto is a bonus layer.",
  "packageManager": "pnpm@11.0.9",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter \"./packages/server\" --filter \"./packages/client\" dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "deploy:client": "scripts/deploy-client.sh",
    "prepare": "lefthook install"
  },
  "license": "UNLICENSED",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "lefthook": "^2.1.9",
    "prettier": "^3.8.4",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.62.0"
  }
}
