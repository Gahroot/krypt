# ─── CryptoMaple production deploy (docker-compose.prod.yml) ─────────────────
# Copy to .env.production and fill in real values. Do NOT commit .env.production.
#
# DNS: create two records pointing at this host's PUBLIC IP before `up`:
#   GAME_DOMAIN    A (and AAAA) → game server  (Colyseus: wss + https API)
#   CLIENT_DOMAIN  A (and AAAA) → static client
GAME_DOMAIN=api.cryptomaple.example
CLIENT_DOMAIN=play.cryptomaple.example
ACME_EMAIL=you@example.com

# Where the browser connects for gameplay. Baked into the client at BUILD time.
# MUST be wss:// — an https page is not allowed to open a plaintext ws://.
# Same host serves the https API (client swaps wss→https internally).
VITE_BACKEND_URL=wss://api.cryptomaple.example

# Only this origin may call the server HTTP API. Never "*" in production.
# Set it to the client's origin: https://CLIENT_DOMAIN
CORS_ORIGIN=https://play.cryptomaple.example

# ─── Secrets — generate a unique strong value for EACH: openssl rand -hex 32 ──
# Signs session tokens (>=16 chars). Stable value ⇒ sessions survive restarts.
AUTH_SECRET=replace-with-openssl-rand-hex-32
# Gates GET /monitor (Colyseus state inspector) in production.
MONITOR_SECRET=replace-with-openssl-rand-hex-32
# Gates the /admin/* moderation routes (ban, mute, announce, …).
ADMIN_SECRET=replace-with-openssl-rand-hex-32

# Optional — session token lifetime in seconds (default 3600, clamped 60..2592000).
AUTH_TOKEN_TTL_SECONDS=3600

# ─── Automated DB backups (the `backup` service) ─────────────────────────────
# Snapshots are written into the data volume at /app/data/backups every interval.
# BACKUP_REMOTE_CMD ships each snapshot OFF-BOX — set it, or the host disk dying
# takes the backups with it. {} is replaced with the snapshot's path.
BACKUP_INTERVAL_SECONDS=86400      # how often to snapshot (default daily)
BACKUP_RETENTION=14                # local snapshots to keep (oldest pruned)
# Examples (need the tool + its credentials available in the container):
#   BACKUP_REMOTE_CMD=rclone copy {} remote:maple-backups
#   BACKUP_REMOTE_CMD=aws s3 cp {} s3://my-bucket/maple/
BACKUP_REMOTE_CMD=
