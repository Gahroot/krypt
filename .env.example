# ─── Server (Colyseus) ───────────────────────────────────────────────
PORT=2567
HOST=0.0.0.0
NODE_ENV=development

# ─── CORS / WS ──────────────────────────────────────────────────────
CORS_ORIGIN=*
MONITOR_SECRET=changeme

# ─── Database ─────────────────────────────────────────────────────────
# SQLite (default for local dev): file path for the database
DATABASE_URL=sqlite://./data/maple.db
# Postgres (production): uncomment when the PG driver is installed
# DATABASE_URL=postgresql://user:pass@localhost:5432/maple

# ─── Client (Vite) ── must be VITE_-prefixed to reach the browser ─────
VITE_BACKEND_URL=ws://localhost:2567

# ═══ Phase 2 — On-chain (Base). NOT used by the game slice yet. ═══════
# Base network RPC endpoints
BASE_RPC_URL=
BASE_SEPOLIA_RPC_URL=

# Server-side signer that authorizes NFT mints on confirmed gameplay.
# NEVER commit a real private key. Use a throwaway key for local/testnet.
MINT_AUTHORIZER_PRIVATE_KEY=

# Deployed contract addresses (filled after Phase 2 deploy)
MAPLE_TOKEN_ADDRESS=
GEAR_NFT_ADDRESS=
ITEM_STACK_ADDRESS=
PREMIUM_MARKET_ADDRESS=

# Chainlink VRF 2.5 (provably-fair rolls)
VRF_COORDINATOR_ADDRESS=
VRF_SUBSCRIPTION_ID=
VRF_KEY_HASH=
