# ─── Server (Colyseus) ───────────────────────────────────────────────
PORT=2567
HOST=0.0.0.0
NODE_ENV=development

# ─── CORS / WS ──────────────────────────────────────────────────────
CORS_ORIGIN=*
MONITOR_SECRET=changeme

# ─── Auth ────────────────────────────────────────────────────────────
# HMAC secret (>=16 chars) for signing session tokens. Set a strong value in
# production so sessions survive restarts. If unset, an ephemeral per-process
# secret is generated (fine for local dev/tests).
AUTH_SECRET=dev-insecure-change-me
# Session-token lifetime in seconds (default 3600 = 1 hour, clamped to 60..2592000).
# Tokens are short-lived; the client refreshes proactively via POST /auth/refresh,
# so long play sessions stay connected without a long-lived credential.
AUTH_TOKEN_TTL_SECONDS=3600

# ─── Logging / observability ─────────────────────────────────────────
# Minimum log level: debug | info | warn | error (default debug in dev, info in prod).
# Logs are one-line JSON (greppable): … | grep '"level":"error"'
LOG_LEVEL=debug
# Set to 1 for human-readable dev logs instead of JSON (ignored in production).
# LOG_PRETTY=1
# Optional error tracker. When set, unhandled exceptions, promise rejections, and
# caught room-handler errors are shipped here. Never logged. Requires @sentry/node
# to be installed; with no DSN nothing is sent off-box.
# SENTRY_DSN=

# ─── Database ─────────────────────────────────────────────────────────
# SQLite (default for local dev): file path for the database
DATABASE_URL=sqlite://./data/maple.db
# Postgres (production): uncomment when the PG driver is installed
# DATABASE_URL=postgresql://user:pass@localhost:5432/maple

# ─── Client (Vite) ── must be VITE_-prefixed to reach the browser ─────
VITE_BACKEND_URL=ws://localhost:2567
# How long (ms) the client waits for a room join before showing a retryable
# "connection timed out" screen. Clamped to 2000..60000, default 12000.
VITE_CONNECT_TIMEOUT_MS=12000

# ═══ Phase 2 — On-chain (Base). NOT used by the game slice yet. ═══════
# Base network RPC endpoints
BASE_RPC_URL=
BASE_SEPOLIA_RPC_URL=

# Server-side signer that authorizes NFT mints on confirmed gameplay.
# NEVER commit a real private key. Use a throwaway key for local/testnet.
MINT_AUTHORIZER_PRIVATE_KEY=

# Deployed contract addresses (filled after Phase 2 deploy)
MAPLE_TOKEN_ADDRESS=
GEAR_NFT_ADDRESS=
ITEM_STACK_ADDRESS=
PREMIUM_MARKET_ADDRESS=

# Chainlink VRF 2.5 (provably-fair rolls)
VRF_COORDINATOR_ADDRESS=
VRF_SUBSCRIPTION_ID=
VRF_KEY_HASH=
